.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B00 0%, #E63946 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-content {
  width: 100%;
  background: #ffffff;
  border-radius: 48rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #E63946 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.app-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.welcome-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.privacy-section {
  margin-bottom: 60rpx;
}

.privacy-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 24rpx;
}

.privacy-text {
  color: #666666;
  margin: 0 4rpx;
}

.privacy-link {
  color: #FF6B00;
  margin: 0 4rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #E63946 100%);
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.login-btn.disabled {
  background: #cccccc;
  box-shadow: none;
  color: #ffffff;
}

.login-btn::after {
  border: none;
}

.tips-section {
  text-align: center;
  margin-top: 40rpx;
}

.tips-text {
  font-size: 22rpx;
  color: #cccccc;
}
