.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5EB 0%, #FFFFFF 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

/* 顶部标题区 */
.header-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B00;
  margin-bottom: 12rpx;
}

.countdown {
  display: block;
  font-size: 26rpx;
  color: #FF8C00;
  background: rgba(255, 107, 0, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  display: inline-block;
}

/* 转盘区域 */
.lottery-box {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 0, 0.1);
  margin-bottom: 40rpx;
  position: relative;
}

/* 指针 */
.pointer-wrap {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.pointer {
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 32rpx solid #FF6B00;
  filter: drop-shadow(0 4rpx 4rpx rgba(0, 0, 0, 0.15));
}

/* 九宫格 */
.lottery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-item {
  background: #F8F9FA;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 4rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 160rpx;
}

.grid-item.active {
  background: linear-gradient(135deg, #FFF0E6 0%, #FFE8D6 100%);
  border-color: #FF6B00;
  transform: scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.25);
}

.prize-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.prize-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 中心按钮 */
.center-cell {
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-btn {
  width: 100%;
  height: 100%;
  min-height: 160rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.center-btn.disabled {
  background: #E0E0E0;
  box-shadow: none;
}

.center-logo {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.logo-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 底部区域 */
.bottom-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.chance-bar {
  text-align: center;
}

.chance-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
