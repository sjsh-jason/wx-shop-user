.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5EB 0%, #FFFFFF 100%);
  padding: 40rpx 30rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B00;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.lottery-box {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 0, 0.1);
  margin-bottom: 40rpx;
}

.lottery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.grid-item {
  background: #F8F9FA;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.grid-item.active {
  background: linear-gradient(135deg, #FFF0E6 0%, #FFE8D6 100%);
  border-color: #FF6B00;
  transform: scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.25);
}

.prize-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.prize-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.start-btn {
  width: 100%;
  padding: 32rpx 0;
  background: linear-gradient(90deg, #FF6B00 0%, #FF8C00 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.35);
}

.start-btn.disabled {
  background: #E8E8E8;
  color: #999;
  box-shadow: none;
}

.tips-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.record-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-prize {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}
