<view class="page-container">
  <view class="header-section">
    <text class="title">{{activityTitle}}</text>
    <text class="countdown" wx:if="{{remainingTime > 0}}">距结束: {{formatCountdown(remainingTime)}}</text>
  </view>

  <view class="lottery-box">
    <view class="lottery-grid">
      <view
        wx:for="{{prizes}}"
        wx:key="id"
        class="grid-item {{currentIndex === index ? 'active' : ''}}"
      >
        <view class="prize-icon">
          <text class="icon-text">{{item.iconText}}</text>
        </view>
        <text class="prize-name">{{item.name}}</text>
      </view>
    </view>

    <view class="start-btn {{isRunning || remainingCount <= 0 ? 'disabled' : ''}}" bindtap="startDraw">
      {{remainingCount <= 0 ? '去获取次数' : (isRunning ? '抽奖中...' : '开始抽奖')}}
    </view>
  </view>

  <view class="chance-section">
    <text class="chance-text">今日可抽: {{remainingCount}} 次</text>
  </view>

  <view class="action-buttons">
    <view class="action-btn" bindtap="goToRule">
      <text class="action-icon">📋</text>
      <text class="action-text">活动规则</text>
    </view>
    <view class="action-btn" bindtap="goToRecords">
      <text class="action-icon">🎁</text>
      <text class="action-text">我的奖品</text>
    </view>
  </view>
</view>
