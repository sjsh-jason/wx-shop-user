.page-container {
  background-color: #f8f9fa;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: white;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B00;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #FF6B00 0%, #FF8C00 100%);
  border-radius: 3rpx;
}

.list-container {
  padding: 20rpx;
}

.exchange-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.product-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.image-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #ffe8d6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.points {
  font-size: 24rpx;
  color: #FF6B00;
  display: flex;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status.status-0 {
  background: #FFF3E0;
  color: #FF6B00;
}

.status.status-1 {
  background: #E8F8EF;
  color: #07C160;
}

.status.status-2 {
  background: #F5F5F5;
  color: #999;
}

.arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
