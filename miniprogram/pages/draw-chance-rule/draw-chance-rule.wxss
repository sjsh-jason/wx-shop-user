.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 20rpx;
}

.rule-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.rule-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rule-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.rule-content {
  padding-top: 20rpx;
}

.rule-field {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rule-field:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.field-input {
  flex: 1;
  min-width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}

.button-section {
  padding: 20rpx 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #ff6b00;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}
