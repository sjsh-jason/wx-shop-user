.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

.record-list {
  padding: 20rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.prize-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.prize-time {
  font-size: 24rpx;
  color: #999999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.prize-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.prize-status.unused {
  background-color: #fff3e0;
  color: #ff9800;
}

.prize-status.used {
  background-color: #e8f5e9;
  color: #4caf50;
}

.prize-status.expired {
  background-color: #f5f5f5;
  color: #999999;
}

.expire-time {
  font-size: 22rpx;
  color: #999999;
}

.empty-tip,
.loading-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}
