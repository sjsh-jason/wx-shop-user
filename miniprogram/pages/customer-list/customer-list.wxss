.page-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 20rpx;
}

.search-section {
  margin-bottom: 24rpx;
}

.search-box {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.stats-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B00;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.customer-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.customer-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.customer-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F5F5F5;
  flex-shrink: 0;
}

.customer-info {
  flex: 1;
  min-width: 0;
}

.customer-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level-badge {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.customer-meta {
  display: flex;
  gap: 16rpx;
}

.customer-phone {
  font-size: 24rpx;
  color: #666;
}

.customer-points {
  font-size: 24rpx;
  color: #FF6B00;
}

.customer-time {
  flex-shrink: 0;
}

.join-date {
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
