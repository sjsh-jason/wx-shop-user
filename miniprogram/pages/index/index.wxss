.page-container {
  padding-bottom: 20rpx;
}

.member-card {
  margin: 30rpx 30rpx 0;
  background: linear-gradient(135deg, #FF6B00 0%, #E63946 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.card-content {
  position: relative;
  z-index: 1;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.level-info {
  display: flex;
  flex-direction: column;
}

.level-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.level-name {
  display: flex;
  align-items: center;
}

.level-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.level-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #ffffff;
  backdrop-filter: blur(10rpx);
}

.progress-section {
  margin-bottom: 32rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #ffffff;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #FCD34D;
  border-radius: 6rpx;
  box-shadow: 0 0 16rpx rgba(252, 211, 77, 0.4);
}

.stats-section {
  display: flex;
  justify-content: space-around;
  padding-top: 32rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.quick-nav {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 48rpx 30rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.nav-orange {
  background: #FFF0E6;
  color: #FF6B00;
}

.nav-red {
  background: #FFE6E6;
  color: #E63946;
}

.nav-yellow {
  background: #FFF9E6;
  color: #FFB703;
}

.nav-green {
  background: #D1FAE5;
  color: #10B981;
}

.nav-pink {
  background: #FFE6F0;
  color: #EC4899;
}

.nav-text {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.banner-section {
  padding: 0 30rpx 48rpx;
}

.banner {
  height: 256rpx;
  background: linear-gradient(135deg, #FFB703 0%, #FF6B00 100%);
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
}

.banner-content {
  position: absolute;
  left: 48rpx;
  top: 50%;
  transform: translateY(-50%);
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  font-style: italic;
}

.banner-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.promo-section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

.promo-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #F5F5F5;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.promo-image {
  width: 192rpx;
  height: 192rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.product-image {
  width: 100%;
  height: 100%;
  background: #F5F5F5;
}

.promo-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: #DC2626;
  color: #ffffff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-bottom-right-radius: 12rpx;
}

.promo-tag-orange {
  background: #F97316;
}

.promo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.promo-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.promo-desc {
  font-size: 20rpx;
  color: #999999;
  font-style: italic;
}

.promo-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-current {
  font-size: 36rpx;
  font-weight: bold;
  color: #DC2626;
}

.price-orange {
  color: #F97316;
}

.price-original {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.group-text {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
}

.buy-btn {
  background: #E63946;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(230, 57, 70, 0.25);
}

.buy-btn-orange {
  background: #F97316;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.25);
}
