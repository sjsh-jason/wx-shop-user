.checkin-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 48rpx;
  box-sizing: border-box;
}

.checkin-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.checkin-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.checkin-subtitle {
  font-size: 26rpx;
  color: #999999;
}

.checkin-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.checkin-icon {
  margin-bottom: 32rpx;
}

.checkin-status {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.checkin-points {
  display: block;
  font-size: 28rpx;
  color: #FF6B00;
  margin-bottom: 48rpx;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  background: #FF6B00;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.disabled {
  background: #CCCCCC;
}

.checkin-btn[disabled] {
  background: #CCCCCC;
}

.checkin-rules {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.rule-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.rule-list {
  display: flex;
  flex-direction: column;
}

.rule-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.link-section {
  text-align: center;
  padding: 24rpx;
}

.link-text {
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 500;
}
