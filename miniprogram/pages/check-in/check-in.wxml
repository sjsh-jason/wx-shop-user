<view class="checkin-container">
  <view class="checkin-header">
    <text class="checkin-title">每日签到</text>
    <text class="checkin-subtitle">连续签到可获得更多积分奖励</text>
  </view>

  <view class="checkin-card">
    <view class="checkin-icon">
      <icon type="success" size="80" color="#FF6B00"></icon>
    </view>
    <text class="checkin-status">{{hasCheckedIn ? '今日已签到' : '今日未签到'}}</text>
    <text class="checkin-points" wx:if="{{checkInInfo}}">获得 {{checkInInfo.points}} 积分</text>
    <text class="checkin-points" wx:elif="{{!hasCheckedIn}}">签到可获得 10 积分</text>

    <button class="checkin-btn {{hasCheckedIn ? 'disabled' : ''}}" bindtap="doCheckIn" disabled="{{hasCheckedIn}}">
      <text class="btn-text">{{hasCheckedIn ? '已签到' : '立即签到'}}</text>
    </button>
  </view>

  <view class="checkin-rules">
    <view class="rule-title">签到规则</view>
    <view class="rule-list">
      <text class="rule-item">1. 每日签到可获得 10 积分</text>
      <text class="rule-item">2. 连续签到 7 天可额外获得 5 积分奖励</text>
      <text class="rule-item">3. 积分可用于积分商城兑换商品和代金券</text>
    </view>
  </view>

  <view class="link-section" bindtap="goToPointsLog">
    <text class="link-text">查看积分明细 ></text>
  </view>
</view>
