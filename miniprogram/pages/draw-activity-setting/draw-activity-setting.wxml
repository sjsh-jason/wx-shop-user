<view class="page-container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">活动标题</text>
      <input class="input" value="{{config.title}}" bindinput="onTitleInput" placeholder="请输入活动标题" />
    </view>
    <view class="form-item">
      <text class="label">开始时间</text>
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="picker">{{startDate || '请选择'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">结束时间</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="picker">{{endDate || '请选择'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">活动规则</text>
      <textarea class="textarea" value="{{config.ruleContent}}" bindinput="onRuleInput" placeholder="请输入活动规则（支持富文本）" />
    </view>
  </view>
  <view class="button-section">
    <button class="save-btn" bindtap="saveConfig" loading="{{saving}}">保存设置</button>
  </view>
</view>
