.page-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 32rpx;
}

.flash-header {
  background: linear-gradient(135deg, #DC2626 0%, #B91C1C 100%);
  padding: 60rpx 30rpx 80rpx;
  position: relative;
}

.header-content {
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  font-style: italic;
  margin-bottom: 24rpx;
}

.countdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.countdown-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.countdown-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.countdown-num {
  background: #ffffff;
  color: #DC2626;
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  min-width: 56rpx;
  text-align: center;
}

.countdown-colon {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.product-list {
  padding: 0 30rpx;
  margin-top: -32rpx;
}

.product-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #FEE2E2;
  box-shadow: 0 8rpx 32rpx rgba(220, 38, 38, 0.1);
}

.product-image {
  width: 224rpx;
  height: 224rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #F5F5F5;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FEE2E2 0%, #FEF3C7 100%);
}

.image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  flex-direction: column;
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.price-current {
  font-size: 40rpx;
  font-weight: bold;
  color: #DC2626;
}

.price-original {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #DC2626 0%, #EF4444 100%);
  border-radius: 8rpx;
}

.progress-text {
  font-size: 18rpx;
  color: #DC2626;
  white-space: nowrap;
}

.buy-btn {
  width: 100%;
  background: linear-gradient(135deg, #DC2626 0%, #B91C1C 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 20rpx 0;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(220, 38, 38, 0.3);
}

.buy-btn::after {
  border: none;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}
