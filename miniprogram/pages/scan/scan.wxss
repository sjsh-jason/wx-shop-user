.scan-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.scan-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.scan-icon {
  width: 160rpx;
  height: 160rpx;
  background: #FFF0E6;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.scan-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.scan-desc {
  font-size: 28rpx;
  color: #999999;
}

.scan-actions {
  margin-bottom: 80rpx;
}

.scan-btn {
  width: 100%;
  height: 96rpx;
  background: #FF6B00;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: none;
}

.scan-btn::after {
  border: none;
}

.scan-btn[disabled] {
  background: #FFB380;
}

.manual-btn {
  width: 100%;
  height: 96rpx;
  background: #ffffff;
  color: #FF6B00;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FF6B00;
}

.manual-btn::after {
  border: none;
}

.manual-btn[disabled] {
  color: #FFB380;
  border-color: #FFB380;
}

.scan-tips {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}
