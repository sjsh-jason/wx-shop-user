.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 20rpx;
}

.rule-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.default-rules {
  line-height: 1.8;
}

.rule-item {
  margin-bottom: 40rpx;
}

.rule-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.rule-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}
