.page-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 32rpx;
}

.points-header {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  margin: 20rpx 30rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.25);
}

.points-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.points-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.points-text {
  display: flex;
  flex-direction: column;
}

.points-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.points-value {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-top: 4rpx;
}

.points-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
}

.points-detail {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.tabs {
  display: flex;
  gap: 48rpx;
  padding: 0 48rpx 32rpx;
  border-bottom: 2rpx solid #F0F0F0;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
  padding-bottom: 16rpx;
  position: relative;
}

.tab-item.active {
  color: #FF6B00;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: #FF6B00;
  border-radius: 2rpx;
}

.product-list {
  padding: 30rpx;
}

.product-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #ffe8d6 100%);
  flex-shrink: 0;
}

.image-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #ffe8d6 100%);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF6B00;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.stock {
  font-size: 22rpx;
  color: #999;
}

.stock.out {
  color: #ff4d4f;
}

.exchanged {
  font-size: 22rpx;
  color: #FF6B00;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.product-points {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.points-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B00;
}

.points-unit {
  font-size: 22rpx;
  color: #999999;
}

.exchange-btn {
  padding: 14rpx 32rpx;
  background: linear-gradient(90deg, #FF6B00 0%, #FF8C00 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
}

.exchange-btn.disabled {
  background: #e8e8e8;
  color: #999;
  box-shadow: none;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
