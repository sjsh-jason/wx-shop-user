<view class="page-container">
  <view class="empty-state" wx:if="{{!loading && logs.length === 0}}">
    <icon type="info" size="48" color="#CCCCCC"></icon>
    <text class="empty-text">暂无积分明细</text>
  </view>

  <view class="log-list" wx:else>
    <view class="log-item" wx:for="{{logs}}" wx:key="id">
      <view class="log-left">
        <text class="log-type">{{item.typeText}}</text>
        <text class="log-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
        <text class="log-time">{{item.timeText}}</text>
      </view>
      <view class="log-right">
        <text class="log-points {{item.typeClass}}">{{item.points > 0 ? '+' : ''}}{{item.points}}</text>
        <text class="log-balance">余额 {{item.balance}}</text>
      </view>
    </view>
  </view>
</view>
