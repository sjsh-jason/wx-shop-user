.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 20rpx;
}

.config-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.config-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-item:last-child {
  border-bottom: none;
}

.config-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.config-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.config-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.config-value {
  padding-top: 10rpx;
}

.switch-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-label {
  font-size: 28rpx;
  color: #666666;
}

.select-wrapper {
  width: 100%;
}

.picker {
  width: 100%;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.button-section {
  padding: 20rpx 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #ff6b00;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}
