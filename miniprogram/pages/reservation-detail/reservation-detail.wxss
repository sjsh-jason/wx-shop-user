.page-container {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 160rpx;
}

.product-section {
  background: #ffffff;
  padding: 40rpx 30rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF6B00;
}

.original-price {
  font-size: 26rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.status-section {
  background: #ffffff;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.status-badge {
  display: inline-block;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.qr-section {
  background: #ffffff;
  padding: 48rpx 30rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.qr-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 32rpx;
}

.qr-box {
  width: 400rpx;
  height: 400rpx;
  background: #ffffff;
  border: 2rpx solid #F0F0F0;
  border-radius: 16rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-canvas {
  width: 360rpx;
  height: 360rpx;
}

.qr-tip {
  font-size: 24rpx;
  color: #999999;
}

.info-section {
  background: #ffffff;
  padding: 0 30rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 30rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.verify-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B00 0%, #E63946 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.verify-btn::after {
  border: none;
}
