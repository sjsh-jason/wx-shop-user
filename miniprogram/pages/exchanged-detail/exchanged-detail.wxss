.page-container {
  padding: 20rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
}

.product-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.product-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff5eb 0%, #ffe8d6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.points-info {
  display: flex;
  align-items: center;
}

.points-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B00;
  margin: 0 8rpx;
}

.points-unit {
  font-size: 24rpx;
  color: #999;
}

.status-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.status-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-item .label {
  font-size: 28rpx;
  color: #999;
}

.status-item .value {
  font-size: 28rpx;
  color: #333;
}

.status-item .value.status-0 {
  color: #FF6B00;
}

.status-item .value.status-1 {
  color: #07C160;
}

.qrcode-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.qrcode-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.qrcode-box {
  width: 200px;
  height: 200px;
  margin: 0 auto;
  background: white;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-canvas {
  width: 200px;
  height: 200px;
}

.qrcode-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 32rpx;
}

.completed-section {
  background: white;
  border-radius: 16rpx;
  padding: 80rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.completed-text {
  display: block;
  font-size: 32rpx;
  color: #07C160;
  margin-top: 24rpx;
  font-weight: 600;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
