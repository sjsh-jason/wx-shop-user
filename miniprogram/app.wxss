page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 16px;
}

.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-orange {
  color: #FF6B00;
}

.text-red {
  color: #E63946;
}

.text-gray {
  color: #999999;
}

.bg-white {
  background-color: #ffffff;
}

.rounded-lg {
  border-radius: 16px;
}

.rounded-xl {
  border-radius: 24px;
}

.shadow-sm {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
